# IPA Compilor — Environment Variables
# Copy to .env and fill in your values. Never commit this file.

# ── Apple Developer ───────────────────────────────────────────
APPLE_TEAM_ID=
APPLE_BUNDLE_ID=com.example.myapp

# ── App Store Connect API ─────────────────────────────────────
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_KEY_PATH=config/app-store-connect-key.p8

# ── Mac Build Agent ───────────────────────────────────────────
MAC_BUILD_HOST=
MAC_BUILD_PORT=22
MAC_BUILD_USER=
MAC_SSH_KEY_PATH=~/.ssh/id_rsa

# ── Code Signing ──────────────────────────────────────────────
SIGNING_CERT_NAME=iPhone Distribution
SIGNING_CERT_PATH=
SIGNING_CERT_PASSWORD=
PROVISIONING_PROFILE_PATH=
PROVISIONING_PROFILE_UUID=

# ── Build Settings ────────────────────────────────────────────
BUILD_CONFIGURATION=Release
EXPORT_METHOD=ad-hoc
PROJECT_NAME=MyApp

# ── Notifications ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ── Debug ─────────────────────────────────────────────────────
IPA_DEBUG=0
